# WorkMind Server 配置
# 复制此文件为 .env 并填入实际值

# DeepSeek API Key（对话 + Embedding 共用）
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# 模型配置
PRIMARY_MODEL=deepseek-chat

# 服务端口
PORT=3000

# CORS 允许源（逗号分隔）
ALLOWED_ORIGINS=http://localhost:5173

# ChromaDB 地址
CHROMA_URL=http://localhost:8000

# 缓存 TTL（毫秒，默认 30 分钟）
CACHE_TTL=1800000

# MinerU KIE 配置（PDF 智能解析）
MINERU_BASE_URL=https://mineru.net/api/kie
MINERU_PIPELINE_ID=
MINERU_API_KEY=
MINERU_TIMEOUT=120
