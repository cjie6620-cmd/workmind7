# ── 应用配置 ──────────────────────────────────────────────
PORT=3001
NODE_ENV=development
# CORS 白名单（逗号分隔）
ALLOWED_ORIGINS=http://localhost:5173

# ── AI 模型配置 ───────────────────────────────────────────
# 必填：DeepSeek API Key
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxx
# 对话模型名称
PRIMARY_MODEL=deepseek-chat
# DeepSeek API 地址
# BASE_URL=https://api.deepseek.com/v1

# ── Embedding 模型 ────────────────────────────────────────
# 本地 bge-m3 模型路径
EMBEDDING_MODEL=D:/huggingface_cache/modelscope/Xorbits/bge-m3
# 推理设备：cpu / cuda
EMBEDDING_DEVICE=cpu
# HuggingFace 缓存目录
HF_HOME=D:/huggingface_cache
# HuggingFace 镜像（国内加速）
HF_ENDPOINT=https://hf-mirror.com

# ── 数据库（PostgreSQL + pgvector）─────────────────────────
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/workmind
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# ── Redis 缓存（可选）─────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ── 缓存配置 ──────────────────────────────────────────────
# 缓存 TTL（毫秒），默认 30 分钟
CACHE_TTL=1800000

# ── MinerU 文档解析（可选）─────────────────────────────────
# MINERU_API_KEY=
# MINERU_TIMEOUT=120
# MINERU_MODEL_VERSION=vlm
