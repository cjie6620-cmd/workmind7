# ── 应用配置 ──────────────────────────────────────────────
PORT=3001
APP_ENV=development
NODE_ENV=development
# CORS 白名单（逗号分隔）
ALLOWED_ORIGINS=http://localhost:5173
# 预算、监控日界线及监控页面展示使用的 IANA 业务时区
BUSINESS_TIMEZONE=Asia/Shanghai

# ── AI 模型配置 ───────────────────────────────────────────
# 必填：DeepSeek API Key
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxx
# 对话模型名称
PRIMARY_MODEL=deepseek-chat
# 单次模型调用的默认上限、超时和可重试次数
LLM_MAX_TOKENS=4096
LLM_TIMEOUT_SECONDS=60
LLM_MAX_RETRIES=2
# 监控、预算与 Prompt 调试共用的模型价格配置（美元/百万 token）
LLM_INPUT_PRICE_USD_PER_MILLION=0.14
LLM_OUTPUT_PRICE_USD_PER_MILLION=0.28
USD_CNY_EXCHANGE_RATE=7.2
# 预算预留使用的最坏输出 token 上限
LLM_BUDGET_MAX_OUTPUT_TOKENS=8192
# DeepSeek API 地址
# BASE_URL=https://api.deepseek.com/v1

# ── Embedding 模型 ────────────────────────────────────────
# 本地 bge-m3 模型路径
EMBEDDING_MODEL=D:/huggingface_cache/modelscope/Xorbits/bge-m3
# 推理设备：cpu / cuda
EMBEDDING_DEVICE=cpu
# HuggingFace 缓存目录
HF_HOME=D:/huggingface_cache
# HuggingFace 镜像（国内加速）
HF_ENDPOINT=https://hf-mirror.com

# ── 数据库（PostgreSQL + pgvector）─────────────────────────
# workmind7 独立中间件：docker compose up -d（端口 5434，见 ../docker-compose.yml）
DATABASE_URL=postgresql+asyncpg://workmind:workmind_dev@localhost:5434/workmind_vector
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# ── Redis 缓存（可选）─────────────────────────────────────
# workmind7 独立中间件：端口 6381（见 ../docker-compose.yml）
REDIS_HOST=localhost
REDIS_PORT=6381
REDIS_PASSWORD=workmind_dev
REDIS_DB=0

# ── 缓存配置 ──────────────────────────────────────────────
# 缓存 TTL（毫秒），默认 30 分钟
CACHE_TTL=1800000

# ── MinerU 文档解析（可选）─────────────────────────────────
# MINERU_API_KEY=
# MINERU_TIMEOUT=120
# MINERU_MODEL_VERSION=vlm

# ── Tavily 联网搜索（Agent web_search 工具）──────────────────
TAVILY_API_KEY=
TAVILY_TIMEOUT=30
TAVILY_MAX_RESULTS=5

# ── JWT 认证（W0b-1a）──────────────────────────────────────
# 启用认证；本地调试可设 false
AUTH_ENABLED=false
# 必填（≥32 字符），AUTH_ENABLED=true 时启动校验；生产环境必须替换为随机值
JWT_SECRET=dev_workmind7_jwt_secret_replace_before_production
JWT_EXPIRE_HOURS=24
JWT_REFRESH_EXPIRE_DAYS=7
# 开发账号（启动时自动 seed 到 users 表）
AUTH_ADMIN_USERNAME=admin
AUTH_ADMIN_PASSWORD=admin123
AUTH_USER_USERNAME=user
AUTH_USER_PASSWORD=user123
# 费用控制
BUDGET_ENFORCE=false
DAILY_BUDGET=50
